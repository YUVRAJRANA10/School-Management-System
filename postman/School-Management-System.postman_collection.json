            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"ABC Public School\",\n  \"address\": \"Sector 10, Noida\",\n  \"latitude\": 28.6,\n  \"longitude\": 77.3\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/addSchool",
          "host": ["{{baseUrl}}"],
          "path": ["addSchool"]
        }
      }
    },
    {
      "name": "List Schools",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/listSchools?latitude=28.6&longitude=77.3",
          "host": ["{{baseUrl}}"],
          "path": ["listSchools"],
          "query": [
            { "key": "latitude", "value": "28.6" },
            { "key": "longitude", "value": "77.3" }
          ]
        }
      }
    },
    {
      "name": "List All Schools",
